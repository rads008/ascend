generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tasks         Task[]
  moods         MoodEntry[]
  reflections   Reflection[]
  identities    Identity[]
  streaks       Streak[]
  pillars       Pillar[]
}

model Pillar {
  id            String    @id @default(cuid())
  name          String
  emoji         String
  color         String
  weeklyGoal    Int       @default(5)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks         Task[]
  createdAt     DateTime  @default(now())
  lastActivity  DateTime?

  @@unique([userId, name])
}

model Task {
  id            String    @id @default(cuid())
  title         String
  pillarId      String
  pillar        Pillar    @relation(fields: [pillarId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  priority      Priority  @default(GROWTH)
  estimatedMins Int       @default(30)
  deadline      DateTime?
  completed     Boolean   @default(false)
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model MoodEntry {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mood          String
  energy        Energy
  date          DateTime  @default(now())
}

model Reflection {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  win           String
  difficulty    String
  mood          String
  tasksCompleted Int      @default(0)
  date          DateTime  @default(now())
}

model Identity {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  description   String
  linkedPillars String[]
  actedToday    Boolean   @default(false)
  consistencyScore Float  @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Streak {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  date          DateTime  @default(now())
  tasksCompleted Int      @default(0)

  @@unique([userId, date])
}

enum Priority {
  CRITICAL
  GROWTH
  LIGHT
}

enum Energy {
  LOW
  MEDIUM
  HIGH
}
